# Clave de API de OpenAI (obligatoria)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de OpenAI
OPENAI_MODEL=gpt-5-mini

# Permitir búsqueda web en tiempo real (consume más tokens y es más lento)
OPENAI_WEB_SEARCH=true

# Activar reasoning (pensamiento interno). Activado por defecto para que compacte respuestas.
OPENAI_REASONING=true

# Límite de tokens de salida. Con reasoning activado, 500 da margen para respuestas de 3 líneas.
OPENAI_MAX_OUTPUT_TOKENS=500

# Identidad y activación del bot
BOT_NAME=Maxuki
BOT_TRIGGER=@bot

# Personalidad del bot: troll (descarada, insulta, trolea) o friendly (amable y útil)
BOT_PERSONALITY=troll

# Servidor HTTP
HTTP_PORT=3000

# Clave secreta para autenticar peticiones del Fabric Bridge (opcional pero recomendada)
API_KEY=cambia-esto-por-una-clave-segura

# Memoria y cooldown
MEMORY_SIZE=10
COOLDOWN_SECONDS=5

# Logging
LOG_LEVEL=info

# Acceso RCON al servidor de Minecraft (habilita comandos para el bot)
RCON_ENABLED=false
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=cambia-esto
